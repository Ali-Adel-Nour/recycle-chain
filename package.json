{
  "name": "recycle-chain",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "libs/*"
    ],
    "nohoist": [
      "**/@nestjs",
      "**/@nestjs/**"
    ]
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "nx": "22.7.0",
    "husky": "^8.0.0"
  },
  "scripts": {
    "format": "prettier \"{apps,libs}/**/*.{ts,tsx,js,json,standalone}\" --ignore-path .gitignore",
    "format:check": "yarn format --check",
    "format:write": "yarn format --write",
    "tsc": "yarn nx run-many -t tsc",
    "lint": "yarn nx run-many -t lint",
    "validate": "yarn format:write && yarn tsc && yarn lint",
    "prepare": "husky install"
  }
}
